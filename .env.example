# Copy this file to .env and fill in your API keys
# Then run: setup_and_run.bat

# Anthropic (Claude) API key — required for Expert Panel, Macro Analysis, AI Screener
# Get free key at: https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_key_here

# FRED API key — required for Market Health macro data (rates, CPI, yield curve)
# Get free key at: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=your_fred_key_here

# Finnhub API key — analyst ratings, price targets, news, EPS estimates, insider transactions
# Get free key at: https://finnhub.io (free: 60 calls/min)
FINNHUB_API_KEY=your_finnhub_key_here
ALPHA_VANTAGE_API_KEY=your_alphavantage_key_here
FMP_API_KEY=your_fmp_key_here
